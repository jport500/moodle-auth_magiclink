{{!
    @template auth_magiclink/login_toggle

    Toggle link added to the standard login form to switch back to magic link mode.

    Example context (json):
    {}
}}

<div class="text-center mt-3">
    <a href="#" id="show-magiclink-form" class="text-decoration-underline">
        {{#str}} orloginwithmagiclink, auth_magiclink {{/str}}
    </a>
</div>
