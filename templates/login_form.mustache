{{!
    @template auth_magiclink/login_form

    Magic link login form template.

    Context variables required for this template:
    * actionurl - The form action URL

    Example context (json):
    {
        "actionurl": "/auth/magiclink/login.php"
    }
}}

<form action="{{actionurl}}" method="post" id="auth-magiclink-form">
    <div class="form-group mb-3">
        <label for="email" class="visually-hidden">{{#str}} email, core {{/str}}</label>
        <input type="email" name="email" id="email" class="form-control form-control-lg" placeholder="{{#str}} email, core {{/str}}" required>
    </div>
    <button type="submit" class="btn btn-primary btn-block w-100">
        {{#str}} sendlink, auth_magiclink {{/str}}
    </button>
    <div class="text-center mt-3">
        <a href="#" id="show-password-form" class="text-decoration-underline">{{#str}} orloginwithpassword, auth_magiclink {{/str}}</a>
    </div>
</form>
