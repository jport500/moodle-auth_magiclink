{{!
    @template auth_magiclink/manage

    Plugin management template.

    Context variables required for this template:
    * hastokens - Boolean if tokens exist
    * tokens - Array of token objects
    * notokens - String for empty tokens message
    * hasaudits - Boolean if audits exist
    * audits - Array of audit log entries
    * noaudits - String for empty audits message

    Example context (json):
    {
        "hastokens": true,
        "tokens": [],
        "notokens": "No tokens found.",
        "hasaudits": true,
        "audits": [],
        "noaudits": "No audit entries."
    }
}}

<div id="auth-magiclink-manage">
    <h3>{{#str}} managelinks, auth_magiclink {{/str}}</h3>
    <div class="auth-magiclink-manage-tokens" id="auth-magiclink-tokens">
        {{#hastokens}}
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th scope="col">{{#str}} col_user, auth_magiclink {{/str}}</th>
                    <th scope="col">{{#str}} col_email, auth_magiclink {{/str}}</th>
                    <th scope="col">{{#str}} col_created, auth_magiclink {{/str}}</th>
                    <th scope="col">{{#str}} col_expires, auth_magiclink {{/str}}</th>
                    <th scope="col">{{#str}} col_status, auth_magiclink {{/str}}</th>
                    <th scope="col">{{#str}} col_actions, auth_magiclink {{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#tokens}}
                <tr>
                    <td>{{fullname}}</td>
                    <td>{{email}}</td>
                    <td>{{#userdate}} {{timecreated}}, %m/%d/%y %H:%M {{/userdate}}</td>
                    <td>{{#userdate}} {{expires}}, %m/%d/%y %H:%M {{/userdate}}</td>
                    <td class="auth-magiclink-status" data-status="{{statuskey}}"><span>{{statuslabel}}</span></td>
                    <td>
                        {{#actions}}
                            <button
                                class="auth-magiclink-action btn"
                                data-action="{{action}}"
                                data-id="{{id}}"
                            >
                                {{action}}
                            </button>
                        {{/actions}}
                    </td>
                </tr>
                {{/tokens}}
            </tbody>
        </table>
        {{/hastokens}}
        {{^hastokens}}
        <div class="alert alert-info">
            {{notokens}}
        </div>
        {{/hastokens}}
    </div>

    <br />

    <h3>{{#str}} auditlog, auth_magiclink {{/str}}</h3>
    <div class="auth-magiclink-manage-audit" id="auth-magiclink-audit">
        {{#hasaudits}}
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th scope="col">{{#str}} col_user, auth_magiclink {{/str}}</th>
                    <th scope="col">{{#str}} col_email, auth_magiclink {{/str}}</th>
                    <th scope="col">{{#str}} col_auditaction, auth_magiclink {{/str}}</th>
                    <th scope="col">{{#str}} col_ip, auth_magiclink {{/str}}</th>
                    <th scope="col">{{#str}} col_info, auth_magiclink {{/str}}</th>
                    <th scope="col">{{#str}} col_timestamp, auth_magiclink {{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#audits}}
                <tr>
                    <td>{{fullname}}</td>
                    <td>{{email}}</td>
                    <td>{{action}}</td>
                    <td>{{ip}}</td>
                    <td>{{info}}</td>
                    <td>{{#userdate}} {{timecreated}}, %m/%d/%y %H:%M {{/userdate}}</td>
                </tr>
                {{/audits}}
            </tbody>
        </table>
        {{/hasaudits}}
        {{^hasaudits}}
        <div class="alert alert-info">
            {{noaudits}}
        </div>
        {{/hasaudits}}
    </div>
</div>
