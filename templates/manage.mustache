{{!
    @template auth_magiclink/manage

    Plugin management template.

    Context variables required for this template:
    * tokens - Array of token objects
    * headers - Table header labels
    * hastokens - Boolean if tokens exist
    * audits - Array of audit log entries
    * headers - Table header labels
    * hasaudits - Boolean if audits exist

    Example context (json):
    {
        "hastokens": true,
        "tokens": []
        "hasaudits": true,
        "audits": []
    }
}}

<div id="auth-magiclink-manage">
    <h3>{{#str}} managelinks, auth_magiclink {{/str}}</h3>
    <div class="auth-magiclink-manage-tokens" id="auth-magiclink-tokens">
        {{#hastokens}}
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th scope="col">User</th>
                    <th scope="col">Email</th>
                    <th scope="col">Created</th>
                    <th scope="col">Expires</th>
                    <th scope="col">Status</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                {{#tokens}}
                <tr>
                    <td>{{fullname}}</td>
                    <td>{{email}}</td>
                    <td>{{#userdate}} {{timecreated}}, %m/%d/%y %H:%M {{/userdate}}</td>
                    <td>{{#userdate}} {{expires}}, %m/%d/%y %H:%M {{/userdate}}</td>
                    <td class="status" data-status="{{used}}"><span>{{used}}</span></td>
                    <td>
                        {{#actions}}
                            <button 
                                class="action btn" 
                                data-action="{{.}}" 
                                data-id="{{id}}"
                            >
                                {{.}}
                            </button>
                        {{/actions}}
                    </td>
                </tr>
                {{/tokens}}
            </tbody>
        </table>
        {{/hastokens}}
        {{^hastokens}}
        <div class="alert alert-info">
            {{notokens}}
        </div>
        {{/hastokens}}
    </div>

    <br />

    <h3>{{#str}} auditlog, auth_magiclink {{/str}}</h3>
    <div class="auth-magiclink-manage-audit" id="auth-magiclink-audit">
        {{#hasaudits}}
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th scope="col">User</th>
                    <th scope="col">Email</th>
                    <th scope="col">Action</th>
                    <th scope="col">IP Address</th>
                    <th scope="col">Info</th>
                    <th scope="col">Timestamp</th>
                </tr>
            </thead>
            <tbody>
                {{#audits}}
                <tr>
                    <td>{{firstname}} {{lastname}}</td>
                    <td>{{email}}</td>
                    <td>{{action}}</td>
                    <td>{{ip}}</td>
                    <td>{{info}}</td>
                    <td>{{#userdate}} {{timecreated}}, %m/%d/%y %H:%M {{/userdate}}</td>
                </tr>
                {{/audits}}
            </tbody>
        </table>
        {{/hasaudits}}
        {{^hasaudits}}
        <div class="alert alert-info">
            {{noaudits}}
        </div>
        {{/hasaudits}}
    </div>
</div>

<style>
    h3 {
        margin-bottom: 1rem;
    }
    .action {
        padding: 0.1rem 0.5rem;
        background: var(--bs-gray-600);
        border-radius: 0.5rem;
        color: white !important;
        text-transform: capitalize;
    }   
    .action:hover {
        filter: brightness(0.85);
    }
    td.status {
        text-transform: capitalize;
    }
    td.status[data-status="unused"] span {
        font-weight: bold;
    }
    .action[data-action="delete"] {
        background: var(--bs-gray-600);
    }
    .action[data-action="revoke"] {
        background: var(--bs-red);
    }
    .action[data-action="extend"] {
        background: var(--bs-green);
    }
</style>